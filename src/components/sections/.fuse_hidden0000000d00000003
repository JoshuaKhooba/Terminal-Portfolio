"use client";
import { useState } from "react";
import { personalInfo } from "@/data/portfolio";
import { GithubIcon, LinkedinIcon } from "@/components/ui/BrandIcons";

export function Contact() {
  const [form, setForm] = useState({ name: "", email: "", message: "" });
  const [sent, setSent] = useState(false);
  const [sending, setSending] = useState(false);

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setSending(true);
    await new Promise(r => setTimeout(r, 1200));
    setSending(false);
    setSent(true);
  };

  return (
    <section id="contact" style={{ padding: "80px 24px" }}>
      <div style={{ maxWidth: 860, margin: "0 auto" }}>
        <div style={{ color: "#1a2540", fontSize: 13, marginBottom: 8 }}>// Get in touch</div>
        <h2 style={{ color: "#4ade80", fontSize: 22, fontWeight: 700, marginBottom: 40 }}>
          $ ./contact.sh
        </h2>

        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 24 }}>
          {/* Left: links */}
          <div className="terminal-card">
            <div style={{ color: "#4a5568", fontSize: 13, marginBottom: 20 }}>$ ls contact/</div>

            {[
              { icon: "✉", label: "email", value: personalInfo.email, href: `mailto:${personalInfo.email}` },
              { icon: null, label: "github", value: "JoshuaKhooba", href: personalInfo.github, GIcon: GithubIcon },
              { icon: null, label: "linkedin", value: "joshua-khooba", href: personalInfo.linkedin, LIcon: LinkedinIcon },
            ].map((item, i) => (
              <a
                key={i}
                href={item.href}
                target={item.href.startsWith("mailto") ? undefined : "_blank"}
                rel="noopener noreferrer"
                style={{ display: "flex", alignItems: "center", gap: 12, padding: "12px 0", borderBottom: "1px solid #1a2540", textDecoration: "none", transition: "color 0.2s" }}
                onMouseEnter={e => { Array.from(e.currentTarget.querySelectorAll<HTMLElement>("span")).forEach(s => s.style.color = "#4ade80"); }}
                onMouseLeave={e => { Array.from(e.currentTarget.querySelectorAll<HTMLElement>("span")).forEach(s => s.style.color = ""); }}
              >
                <span style={{ color: "#4a5568", width: 20, display: "flex", justifyContent: "center" }}>
                  {item.GIcon ? <item.GIcon size={16} /> : item.LIcon ? <item.LIcon size={16} /> : item.icon}
                </span>
                <div>
                  <div style={{ color: "#4a5568", fontSize: 11 }}>{item.label}</div>
                  <div style={{ color: "#94a3b8", fontSize: 13 }}>{item.value}</div>
                </div>
              </a>
            ))}

            <a
              href={personalInfo.resumeUrl}
              download
              className="btn-green"
              style={{ marginTop: 20, width: "100%", justifyContent: "center" }}
            >
              ↓ download_cv()
            </a>
          </div>

          {/* Right: form */}
          <div className="terminal-card">
            <div style={{ color: "#4a5568", fontSize: 13, marginBottom: 20 }}>$ ./send_message.sh</div>

            {sent ? (
              <div style={{ textAlign: "center", padding: "40px 0" }}>
                <div style={{ color: "#4ade80", fontSize: 32, marginBottom: 12 }}>✓</div>
                <div style={{ color: "#4ade80", fontSize: 14 }}>Message sent successfully!</div>
                <div style={{ color: "#4a5568", fontSize: 12, marginTop: 8 }}>I&apos;ll get back to you soon.</div>
              </div>
            ) : (
              <form onSubmit={handleSubmit} style={{ display: "flex", flexDirection: "column", gap: 14 }}>
                {[
                  { key: "name", placeholder: "your_name", type: "text" },
                  { key: "email", placeholder: "your_email@domain.com", type: "email" },
                ].map(field => (
                  <div key={field.key}>
                    <div style={{ color: "#4a5568", fontSize: 11, marginBottom: 4 }}>$ {field.key}</div>
                    <input
                      type={field.type}
                      required
                      placeholder={field.placeholder}
                      value={form[field.key as keyof typeof form]}
                      onChange={e => setForm({ ...form, [field.key]: e.target.value })}
                      style={{
                        width: "100%", backgroundColor: "#090d18", border: "1px solid #1a2540",
                        borderRadius: 6, padding: "10px 12px", color: "#e2e8f0", fontSize: 13,
                        fontFamily: "inherit", outline: "none", transition: "border-color 0.2s",
                      }}
                      onFocus={e => (e.target as HTMLInputElement).style.borderColor = "#4ade80"}
                      onBlur={e => (e.target as HTMLInputElement).style.borderColor = "#1a2540"}
                    />
                  </div>
                ))}
                <div>
                  <div style={{ color: "#4a5568", fontSize: 11, marginBottom: 4 }}>$ message</div>
                  <textarea
                    required
                    rows={4}
                    placeholder="Your message here..."
                    value={form.message}
                    onChange={e => setForm({ ...form, message: e.target.value })}
                    style={{
                      width: "100%", backgroundColor: "#090d18", border: "1px solid #1a2540",
                      borderRadius: 6, padding: "10px 12px", color: "#e2e8f0", fontSize: 13,
                      fontFamily: "inherit", outline: "none", resize: "vertical",
                      transition: "border-color 0.2s",
                    }}
                    onFocus={e => (e.target as HTMLTextAreaElement).style.borderColor = "#4ade80"}
                    onBlur={e => (e.target as HTMLTextAreaElement).style.borderColor = "#1a2540"}
                  />
                </div>
                <button type="submit" className="btn-green" disabled={sending} style={{ width: "100%", justifyContent: "center" }}>
                  {sending ? "sending..." : "$ send_message()"}
                </button>
              </form>
            )}
          </div>
        </div>
      </div>
    </section>
  );
}
